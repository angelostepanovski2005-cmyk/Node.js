<!DOCTYPE html>
<html lang="mk">
<head>
    <meta charset="UTF-8">
    <title>Анализа на Текст</title>
</head>
<body>
    <h2>Анализатор на текст</h2>
    <form action="/analiza" method="POST">
        <label for="text">Внесете го вашиот текст:</label><br><br>
        <textarea id="text" name="text" rows="10" cols="60" placeholder="Внеси го текстот тука..." required></textarea>
        <br><br>
        <button type="submit">Анализирај</button>
    </form>
</body>
</html>